// Zenbourg Hotel Management System - Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ========================================
// USERS & AUTHENTICATION
// ========================================

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String    @unique
  phone         String    @unique
  password      String
  role          UserRole
  status        UserStatus @default(ACTIVE)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  workplaceId   String?    @db.ObjectId
  myWorkplace   Property?  @relation("WorkerRelation", fields: [workplaceId], references: [id])
  
  ownedPropertyIds String[] @db.ObjectId
  ownedProperties Property[] @relation("OwnershipRelation", fields: [ownedPropertyIds], references: [id])
  staffProfile  Staff?

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  HOTEL_ADMIN
  MANAGER
  RECEPTIONIST
  STAFF
  GUEST
}

enum UserStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

// ========================================
// GUESTS
// ========================================

model Guest {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  email             String?
  phone             String    @unique
  idType            String?   // Aadhaar, Passport, etc.
  idNumber          String?
  idDocumentFront   String?   // URL to uploaded document
  idDocumentBack    String?
  address           String?

  checkInStatus     CheckInStatus @default(PENDING)
  checkInCompletedAt DateTime?

  language          String    @default("English")
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  bookings          Booking[]
  serviceRequests   ServiceRequest[]
  ratings           Rating[]
  favorites         Favorite[]

  @@map("guests")
}

model Favorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  guestId   String   @db.ObjectId
  guest     Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  
  roomId    String   @db.ObjectId
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([guestId, roomId])
  @@map("favorites")
}

enum CheckInStatus {
  PENDING
  LINK_SENT
  LINK_OPENED
  COMPLETED
  VERIFIED
}

// ========================================
// PROPERTIES & ROOMS
// ========================================

model Property {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  description   String?
  address       String
  phone         String
  email         String
  logo          String?
  coverImage    String?
  images        String[]  

  // Operating Hours
  checkInTime   String    @default("14:00")
  checkOutTime  String    @default("11:00")

  // Policies
  cancellationPolicy String?
  policies      Json?     // Flexible JSON for various policies

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  ownerIds      String[]   @db.ObjectId
  owners        User[]     @relation("OwnershipRelation", fields: [ownerIds], references: [id])
  
  workerList    User[]     @relation("WorkerRelation")
  rooms         Room[]     @relation("PropertyToRoom")
  amenities     Amenity[]  @relation("PropertyToAmenity")
  menuItems     MenuItem[] @relation("PropertyToMenuItem")
  spaServices   SpaService[] @relation("PropertyToSpaService")
  staff         Staff[]          @relation("PropertyToStaff")
  bookings      Booking[]        @relation("PropertyToBooking")
  serviceRequests ServiceRequest[] @relation("PropertyToServiceRequest")
  rolePermissions RolePermission[] @relation("PropertyToRolePermission")

  @@map("properties")
}

model Room {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  propertyId    String    @db.ObjectId
  property      Property  @relation("PropertyToRoom", fields: [propertyId], references: [id], onDelete: Cascade)

  roomNumber    String
  floor         Int
  category      RoomCategory
  type          String    // Standard King, Deluxe Twin, etc.

  maxOccupancy  Int
  basePrice     Float

  amenities     String[]  
  images        String[]  
  description   String?

  status        RoomStatus @default(AVAILABLE)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  bookings      Booking[]
  serviceRequests ServiceRequest[]
  favorites     Favorite[]

  @@unique([propertyId, roomNumber])
  @@map("rooms")
}

enum RoomCategory {
  STANDARD
  DELUXE
  SUITE
  PENTHOUSE
  CUSTOM
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  BLOCKED
  CLEANING
}

// ========================================
// BOOKINGS
// ========================================

model Booking {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId

  guestId       String    @db.ObjectId
  guest         Guest     @relation(fields: [guestId], references: [id])

  roomId        String    @db.ObjectId
  room          Room      @relation(fields: [roomId], references: [id])

  checkIn       DateTime
  checkOut      DateTime

  numberOfGuests Int

  status        BookingStatus @default(RESERVED)
  source        BookingSource @default(DIRECT)

  totalAmount   Float
  paidAmount    Float     @default(0)
  paymentStatus PaymentStatus @default(PENDING)

  specialRequests String?
  notes         String?

  propertyId    String    @db.ObjectId
  property      Property  @relation("PropertyToBooking", fields: [propertyId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("bookings")
}

enum BookingStatus {
  RESERVED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum BookingSource {
  WALK_IN
  DIRECT
  BOOKING_COM
  MAKE_MY_TRIP
  AGODA
  EXPEDIA
  AIRBNB
  OTHER
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

// ========================================
// SERVICES & ORDERS
// ========================================

model ServiceRequest {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId

  type          ServiceType

  guestId       String?   @db.ObjectId
  guest         Guest?    @relation(fields: [guestId], references: [id])

  roomId        String?   @db.ObjectId
  room          Room?     @relation(fields: [roomId], references: [id])

  propertyId    String    @db.ObjectId
  property      Property  @relation("PropertyToServiceRequest", fields: [propertyId], references: [id])

  title         String
  description   String?
  priority      Priority  @default(NORMAL)

  assignedToId  String?   @db.ObjectId
  assignedTo    Staff?    @relation(fields: [assignedToId], references: [id])

  status        ServiceStatus @default(PENDING)

  // SLA Tracking
  slaMinutes    Int       @default(60)  // Default 60 minutes
  createdAt     DateTime  @default(now())
  acceptedAt    DateTime?
  startedAt     DateTime?
  completedAt   DateTime?

  // Payment (for food orders)
  amount        Float?
  paymentStatus PaymentStatus?

  attachments   String[]  
  notes         String?

  updatedAt     DateTime  @updatedAt

  // Relations
  ratings       Rating[]

  @@map("service_requests")
}

enum ServiceType {
  HOUSEKEEPING
  FOOD_ORDER
  ROOM_SERVICE
  LAUNDRY
  MAINTENANCE
  CONCIERGE
  SPA
}

enum ServiceStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ========================================
// STAFF & HR
// ========================================

model Staff {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId

  userId        String    @unique @db.ObjectId
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  propertyId    String    @db.ObjectId
  property      Property  @relation("PropertyToStaff", fields: [propertyId], references: [id], onDelete: Cascade)

  employeeId    String    @unique
  dateOfBirth   DateTime?
  dateOfJoining DateTime  @default(now())

  department    Department
  designation   String

  // Compensation
  baseSalary    Float
  bankName      String?
  accountNumber String?
  ifscCode      String?

  // Emergency Contact
  emergencyContactName  String?
  emergencyContactPhone String?

  profilePhoto  String?
  documents     Json?     // Store various documents

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  attendances   Attendance[]
  leaveRequests LeaveRequest[]
  serviceRequests ServiceRequest[]
  payrolls      Payroll[]
  performanceScores PerformanceScore[]

  @@map("staff")
}

enum Department {
  FRONT_DESK
  HOUSEKEEPING
  KITCHEN
  ROOM_SERVICE
  MAINTENANCE
  SECURITY
  ACCOUNTS
  MANAGEMENT
}

// ========================================
// ATTENDANCE
// ========================================

model Attendance {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId

  staffId       String    @db.ObjectId
  staff         Staff     @relation(fields: [staffId], references: [id])

  date          DateTime 

  punchIn       DateTime?
  punchOut      DateTime?

  punchInLocation  String?
  punchOutLocation String?

  status        AttendanceStatus @default(ABSENT)

  // Working Hours
  hoursWorked   Float?
  overtimeHours Float     @default(0)

  notes         String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([staffId, date])
  @@map("attendances")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
}

// ========================================
// LEAVE MANAGEMENT
// ========================================

model LeaveRequest {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId

  staffId       String    @db.ObjectId
  staff         Staff     @relation(fields: [staffId], references: [id])

  leaveType     LeaveType
  startDate     DateTime 
  endDate       DateTime 
  totalDays     Int

  reason        String

  status        LeaveStatus @default(PENDING)

  approvedBy    String?
  approvedAt    DateTime?

  rejectionReason String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("leave_requests")
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ========================================
// PAYROLL & INCENTIVES
// ========================================

model Payroll {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId

  staffId       String    @db.ObjectId
  staff         Staff     @relation(fields: [staffId], references: [id])

  month         String    // Format: YYYY-MM
  year          Int

  // Salary Components
  baseSalary    Float
  overtimePay   Float     @default(0)
  incentives    Float     @default(0)
  bonuses       Float     @default(0)
  deductions    Float     @default(0)
  netSalary     Float

  // Status
  status        PayrollStatus @default(PENDING)
  paidAt        DateTime?

  // Calculations Breakdown
  breakdown     Json?     // Detailed breakdown of calculations

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([staffId, month, year])
  @@map("payrolls")
}

enum PayrollStatus {
  PENDING
  APPROVED
  PAID
}

// ========================================
// PERFORMANCE & RATINGS
// ========================================

model Rating {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId

  guestId       String    @db.ObjectId
  guest         Guest     @relation(fields: [guestId], references: [id])

  serviceRequestId String?  @db.ObjectId
  serviceRequest   ServiceRequest? @relation(fields: [serviceRequestId], references: [id])

  // Can be for service or overall stay
  type          RatingType

  rating        Int       // 1-5
  comment       String?

  createdAt     DateTime  @default(now())

  @@map("ratings")
}

enum RatingType {
  SERVICE
  OVERALL_STAY
  CLEANLINESS
  FOOD
  STAFF
}

model PerformanceScore {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId

  staffId       String    @db.ObjectId
  staff         Staff     @relation(fields: [staffId], references: [id])

  month         String    // Format: YYYY-MM
  year          Int

  // Metrics
  tasksCompleted Int      @default(0)
  tasksOnTime   Int       @default(0)
  avgRating     Float?
  slaBreaches   Int       @default(0)

  // Calculated Score
  overallScore  Float?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([staffId, month, year])
  @@map("performance_scores")
}

// ========================================
// HOTEL CONTENT
// ========================================

model Amenity {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId

  propertyId    String    @db.ObjectId
  property      Property  @relation("PropertyToAmenity", fields: [propertyId], references: [id], onDelete: Cascade)

  name          String
  description   String?
  icon          String?
  category      String?   // Pool, Gym, Spa, etc.
  isActive      Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("amenities")
}

model MenuItem {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId

  propertyId    String    @db.ObjectId
  property      Property  @relation("PropertyToMenuItem", fields: [propertyId], references: [id], onDelete: Cascade)

  name          String
  description   String?
  category      String    // Breakfast, Lunch, Dinner, Beverages
  cuisine       String?   // Indian, Chinese, Continental, etc.

  price         Float
  image         String?

  isVeg         Boolean   @default(true)
  isAvailable   Boolean   @default(true)

  prepTime      Int?      // In minutes

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("menu_items")
}

model SpaService {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId

  propertyId    String    @db.ObjectId
  property      Property  @relation("PropertyToSpaService", fields: [propertyId], references: [id], onDelete: Cascade)

  name          String
  description   String?
  duration      Int       // In minutes
  price         Float
  image         String?

  isAvailable   Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("spa_services")
}

// ========================================
// SYSTEM CONFIGURATION
// ========================================

model RolePermission {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  propertyId  String   @db.ObjectId
  property    Property @relation("PropertyToRolePermission", fields: [propertyId], references: [id], onDelete: Cascade)
  
  role        UserRole
  permissions Json     // Map of permissions: { "rooms": "READ_WRITE", "payroll": "NONE", etc. }
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([propertyId, role])
  @@map("role_permissions")
}

model SystemSetting {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId

  key           String    @unique
  value         String
  description   String?

  updatedAt     DateTime  @updatedAt

  @@map("system_settings")
}

model NotificationTemplate {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId

  name          String    @unique
  type          NotificationType
  channel       NotificationChannel

  subject       String?   // For email
  template      String    // Template content with variables

  isActive      Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("notification_templates")
}

enum NotificationType {
  CHECK_IN_LINK
  BOOKING_CONFIRMATION
  CHECK_IN_REMINDER
  CHECK_OUT_REMINDER
  SERVICE_REQUEST_UPDATE
  PAYMENT_RECEIPT
  STAFF_TASK_ASSIGNED
  LEAVE_APPROVED
  SALARY_CREDITED
}

enum NotificationChannel {
  SMS
  EMAIL
  WHATSAPP
  PUSH
  IN_APP
}
